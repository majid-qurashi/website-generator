// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles enum
enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

// Website status enum
enum WebsiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Page types enum
enum PageType {
  HOME
  ABOUT
  CONTACT
  GALLERY
  NEWS
  CUSTOM
}

// User model - School administrators and staff
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      UserRole @default(EDITOR)
  isActive  Boolean  @default(true)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// School model - Main school entity
model School {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?
  website     String?
  description String?

  // Profile information
  tagline       String?
  logoUrl       String?
  bannerUrl     String?
  primaryColor  String?
  secondaryColor String?

  // Subscription/Plan info
  planType    String   @default("FREE")
  planExpires DateTime?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users    User[]
  websites Website[]

  @@map("schools")
}

// Template model - Website templates available to schools
model Template {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String?
  thumbnailUrl String?

  // Template structure (JSON)
  structure   Json

  // Template settings
  isPublic    Boolean @default(true)
  isPremium   Boolean @default(false)
  price       Float?  // For premium templates

  // Usage stats
  usageCount  Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  websites Website[]

  @@map("templates")
}

// Website model - Websites created by schools
model Website {
  id         String   @id @default(cuid())
  name       String
  domain     String?  @unique // Custom domain
  subdomain  String?  @unique // Auto-generated subdomain

  status     WebsiteStatus @default(DRAFT)

  // SEO settings
  metaTitle       String?
  metaDescription String?
  faviconUrl      String?

  // Analytics
  googleAnalyticsId String?

  schoolId   String
  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  publishedAt DateTime?

  // Relations
  pages Page[]

  @@map("websites")
}

// Page model - Individual pages within websites
model Page {
  id       String   @id @default(cuid())
  title    String
  slug     String   // URL slug
  content  Json     // Page content structure
  type     PageType @default(CUSTOM)

  // Page settings
  isPublished Boolean @default(false)
  order       Int      @default(0) // For ordering pages
  parentId    String?  // For nested pages
  parent      Page?    @relation("PageHierarchy", fields: [parentId], references: [id])
  children    Page[]   @relation("PageHierarchy")

  // SEO
  metaTitle       String?
  metaDescription String?
  keywords        String?

  websiteId String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([websiteId, slug])
  @@map("pages")
}
